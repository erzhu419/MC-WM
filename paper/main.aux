\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces \textbf  {MC-WM pipeline.} Sim and real transitions feed a frozen ensemble world model $\hat  M_{\mathrm  {sim}}$ and a SINDy\,+\,NAU residual $\hat  \delta $. Imagined rollouts from $\hat  M_{\mathrm  {sim}}+\hat  \delta $ are gated by a Bellman $Q^{\Delta }$ critic and a constraint system before being added to the policy replay buffer. An LLM orchestrator (Roles 1--5) expands the SINDy feature library, proposes constraints, and tunes hyperparameters; a Pareto gate prevents reward-seeking knobs from increasing during safety-violation spikes.\relax }}{4}{figure.caption.12}\protected@file@percent }
\providecommand*\caption@xref[2]{\@setref\relax\@undefined{#1}}
\newlabel{fig:arch}{{1}{4}{\textbf {MC-WM pipeline.} Sim and real transitions feed a frozen ensemble world model $\hat M_{\mathrm {sim}}$ and a SINDy\,+\,NAU residual $\hat \delta $. Imagined rollouts from $\hat M_{\mathrm {sim}}+\hat \delta $ are gated by a Bellman $\QD $ critic and a constraint system before being added to the policy replay buffer. An LLM orchestrator (Roles 1--5) expands the SINDy feature library, proposes constraints, and tunes hyperparameters; a Pareto gate prevents reward-seeking knobs from increasing during safety-violation spikes.\relax }{figure.caption.12}{}}
