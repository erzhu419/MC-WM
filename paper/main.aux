\@writefile{toc}{\contentsline {subsection}{\numberline {6.5}When Residual Correction Fails: Negative Results and Gap Taxonomy}{10}{subsection.6.5}\protected@file@percent }
\newlabel{sec:taxonomy}{{6.5}{10}{When Residual Correction Fails: Negative Results and Gap Taxonomy}{subsection.6.5}{}}
\@writefile{lot}{\contentsline {table}{\numberline {5}{\ignorespaces \textbf  {Environments where MC-WM hurts.} Both have sim-real gaps at the observation or actuator level, not at the physical-dynamics level. c9 means over 3 seeds. Appendix\nobreakspace  {}\ref  {app:beta} reports a follow-up $\beta $-scaling study that also failed, confirming that the issue is structural (Thm.\nobreakspace  {}\ref  {thm:universal-false}), not a scalar mis-calibration.\relax }}{11}{table.caption.28}\protected@file@percent }
\newlabel{tab:neg}{{5}{11}{\textbf {Environments where MC-WM hurts.} Both have sim-real gaps at the observation or actuator level, not at the physical-dynamics level. c9 means over 3 seeds. Appendix~\ref {app:beta} reports a follow-up $\beta $-scaling study that also failed, confirming that the issue is structural (Thm.~\ref {thm:universal-false}), not a scalar mis-calibration.\relax }{table.caption.28}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces \textbf  {Gap taxonomy.} $c9/c1$ return ratio vs.\ residual improvement ratio on real data. Residual correction is effective iff the gap exceeds $\sim 35\%$. Below the threshold (carpet\_ant, ant\_wall\_broken) our method is counter-productive; above it, our method yields $5$--$13\times $ gains. The two negative-result environments are plotted in red.\relax }}{11}{figure.caption.29}\protected@file@percent }
\newlabel{fig:taxonomy}{{4}{11}{\textbf {Gap taxonomy.} $c9/c1$ return ratio vs.\ residual improvement ratio on real data. Residual correction is effective iff the gap exceeds $\sim 35\%$. Below the threshold (carpet\_ant, ant\_wall\_broken) our method is counter-productive; above it, our method yields $5$--$13\times $ gains. The two negative-result environments are plotted in red.\relax }{figure.caption.29}{}}
